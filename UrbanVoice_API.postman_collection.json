            ],
            "url": { "raw": "{{baseUrl}}/api/auth/password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"citizen123\",\n  \"newPassword\": \"newpass456\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "🏗️ Issues",
      "item": [
        {
          "name": "Create Issue (with photo) — Citizen",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/issues/create", "host": ["{{baseUrl}}"], "path": ["api", "issues", "create"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",          "value": "Large pothole on Main Road",       "type": "text" },
                { "key": "description",    "value": "There is a large pothole near the market crossing causing accidents and traffic jams every morning.", "type": "text" },
                { "key": "category",       "value": "Road & Infrastructure",            "type": "text" },
                { "key": "priority",       "value": "High",                             "type": "text" },
                { "key": "address",        "value": "Main Road, Near Market, Block A",  "type": "text" },
                { "key": "coordinates",    "value": "18.5204, 73.8567",                 "type": "text" },
                { "key": "block",          "value": "Block A",                          "type": "text" },
                { "key": "citizenContact", "value": "priya@example.com",               "type": "text" },
                { "key": "photo",          "type": "file", "src": "" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Issue (no photo) — Citizen",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/issues/create", "host": ["{{baseUrl}}"], "path": ["api", "issues", "create"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Broken street light on Park Road\",\n  \"description\": \"The street light near the park entrance has been broken for 2 weeks causing safety issues for pedestrians.\",\n  \"category\": \"Electricity & Lighting\",\n  \"priority\": \"Medium\",\n  \"address\": \"Park Road, Block B\",\n  \"coordinates\": \"18.5300, 73.8450\",\n  \"block\": \"Block B\",\n  \"citizenContact\": \"priya@example.com\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get My Issues — Citizen",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/issues/my", "host": ["{{baseUrl}}"], "path": ["api", "issues", "my"] }
          },
          "response": []
        },
        {
          "name": "Get All Issues — Admin (with filters)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/issues/all?block=Block A&status=Reported&category=Road %26 Infrastructure&priority=High",
              "host": ["{{baseUrl}}"],
              "path": ["api", "issues", "all"],
              "query": [
                { "key": "block",    "value": "Block A" },
                { "key": "status",   "value": "Reported" },
                { "key": "category", "value": "Road & Infrastructure" },
                { "key": "priority", "value": "High" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Block Issues — Officer",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/issues/block", "host": ["{{baseUrl}}"], "path": ["api", "issues", "block"] }
          },
          "response": []
        },
        {
          "name": "Update Issue Status — Officer/Admin",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/issues/ISSUE_ID_HERE/status", "host": ["{{baseUrl}}"], "path": ["api", "issues", "ISSUE_ID_HERE", "status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"In Progress\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Toggle Duplicate Flag — Officer/Admin",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/issues/ISSUE_ID_HERE/duplicate", "host": ["{{baseUrl}}"], "path": ["api", "issues", "ISSUE_ID_HERE", "duplicate"] }
          },
          "response": []
        },
        {
          "name": "Delete Issue — Admin",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/issues/ISSUE_ID_HERE", "host": ["{{baseUrl}}"], "path": ["api", "issues", "ISSUE_ID_HERE"] }
          },
          "response": []
        }
      ]
    },
