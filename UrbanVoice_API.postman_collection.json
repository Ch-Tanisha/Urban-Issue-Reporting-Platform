            }
          },
          "response": []
        },
        {
          "name": "Get My Profile (GET /me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          },
          "response": []
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api", "auth", "profile"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya Sharma Updated\",\n  \"phone\": \"9999999999\",\n  \"address\": \"45 Nehru Road\",\n  \"city\": \"Pune\",\n  \"pincode\": \"411002\",\n  \"block\": \"Block B\",\n  \"age\": 29,\n  \"gender\": \"Female\"\n}"
            }
          },
          "response": []
        },
