{
  "info": {
    "name": "UrbanVoice — Urban Issue Reporting Platform API",
    "_postman_id": "urbanvoice-api-collection-2024",
    "description": "Complete REST API collection for the Urban Issue Reporting Platform. Base URL: http://localhost:5000\n\nRoles: citizen | blockofficer | admin\n\nAuthentication: Bearer JWT token in Authorization header.\nAfter login/register, copy the token from the response and set it as {{token}} in your environment variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "token",   "value": "YOUR_JWT_TOKEN_HERE",    "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register — Citizen",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya Sharma\",\n  \"email\": \"priya@example.com\",\n  \"password\": \"citizen123\",\n  \"phone\": \"9876543210\",\n  \"role\": \"citizen\",\n  \"age\": 28,\n  \"gender\": \"Female\",\n  \"address\": \"12 Gandhi Nagar\",\n  \"city\": \"Pune\",\n  \"pincode\": \"411001\",\n  \"block\": \"Block A\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Register — Block Officer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rahul Patil\",\n  \"email\": \"rahul.officer@example.com\",\n  \"password\": \"officer123\",\n  \"phone\": \"9123456789\",\n  \"role\": \"blockofficer\",\n  \"block\": \"Block A\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Register — Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@urbanvoice.com\",\n  \"password\": \"admin123\",\n  \"role\": \"admin\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login — Citizen",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"priya@example.com\",\n  \"password\": \"citizen123\",\n  \"role\": \"citizen\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login — Block Officer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rahul.officer@example.com\",\n  \"password\": \"officer123\",\n  \"role\": \"officer\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login — Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
